{
  "name": "corndocs-components",
  "description": "Components for CornDocs",
  "author": "Kenneth",
  "keywords": [
    "nextjs",
    "components",
    "ui"
  ],
  "version": "0.1.2",
  "private": false,
  "main": "dist/index.ts",
  "module": "dist/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dishwasher-detergent/CornDocs/tree/core"
  },
  "scripts": {
    "remove": "rimraf dist",
    "bundle": "babel ./components --out-dir dist --copy-files",
    "copy": "copyfiles ./styles/* ./dist && copyfiles ./hooks/* ./dist && copyfiles ./types/* ./dist && copyfiles ./context/* ./dist",
    "build": "npm run remove && npm run bundle && npm run copy"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "@headlessui/react": "^1.7.2",
    "@mdx-js/loader": "^2.1.3",
    "@mdx-js/react": "^2.1.3",
    "@next/mdx": "^12.3.1",
    "@tailwindcss/line-clamp": "^0.3.1",
    "algoliasearch": "^4.14.2",
    "copyfiles": "^2.4.1",
    "directory-tree": "^3.3.1",
    "dotenv": "^16.0.3",
    "framer-motion": "^6.5.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.92.0",
    "next": "12.3.1",
    "nprogress": "^0.2.0",
    "prismjs": "^1.26.0",
    "react": "17.0.2",
    "react-copy-to-clipboard": "^5.0.4",
    "react-dom": "17.0.2",
    "react-instantsearch": "^6.38.0",
    "react-instantsearch-dom": "^6.38.0",
    "remark-frontmatter": "3.0.0",
    "remark-gfm": "^1.0.0",
    "rimraf": "^3.0.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.19.3",
    "@babel/core": "^7.20.2",
    "@babel/preset-env": "^7.20.2",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "17.0.8",
    "@types/nprogress": "^0.2.0",
    "@types/prismjs": "^1.26.0",
    "@types/react": "17.0.38",
    "@types/react-copy-to-clipboard": "^5.0.2",
    "@types/react-dom": "^18.0.6",
    "@types/react-instantsearch-dom": "^6.12.3",
    "autoprefixer": "^10.4.2",
    "eslint": "8.7.0",
    "eslint-config-next": "12.0.8",
    "postcss": "^8.4.5",
    "prettier": "2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "tailwindcss": "^3.0.15",
    "typescript": "4.5.4"
  }
}
